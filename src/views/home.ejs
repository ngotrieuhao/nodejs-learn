<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
  </head>
  <body>
    <div
      style="
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 25px;
      "
    >
      <h1>List Users</h1>
      <div>
        <a href="/admin/create" class="btn btn-warning">Create a new user</a>
      </div>
    </div>
    <hr />
    <table class="table table-hover table-bordered">
      <thead>
        <th>Id</th>
        <th>Name</th>
        <th>Email</th>
        <th>Address</th>
        <th>Action</th>
      </thead>
      <tbody>
        <% users.forEach(function(result){%>
         <tr>
          <td><%= result.id %></td>
          <td><%= result.fullName %></td>
          <td><%= result.username %></td>
          <td><%= result.address %></td>
          <td>
            <div style="display: flex; gap: 10px">

              <form action="/admin/view-user/<%= result.id %>" method="get">
                <button type="submit" class="btn btn-warning">View</button>
              </form>
              <form action="/admin/delete-user/<%= result.id %>" method="post">
                <button type="submit" class="btn btn-danger">Delete</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </body>
</html>
